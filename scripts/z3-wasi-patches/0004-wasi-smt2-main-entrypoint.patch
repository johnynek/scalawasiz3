--- /dev/null
+++ b/src/shell/smt2_main.cpp
@@ -0,0 +1,63 @@
+#include <iostream>
+#include <iterator>
+#include <string>
+
+#include "api/z3.h"
+
+namespace {
+std::string read_all_stdin() {
+    return std::string(std::istreambuf_iterator<char>(std::cin), std::istreambuf_iterator<char>());
+}
+
+bool has_exit_command(std::string const& s) {
+    return s.find("(exit)") != std::string::npos;
+}
+} // namespace
+
+int main() {
+    std::string input = read_all_stdin();
+    if (input.empty()) {
+        return 0;
+    }
+    if (input.back() != '\n') {
+        input.push_back('\n');
+    }
+    if (!has_exit_command(input)) {
+        input += "(exit)\n";
+    }
+
+    Z3_config cfg = Z3_mk_config();
+    if (!cfg) {
+        std::cerr << "(error \"failed to create Z3 config\")\n";
+        return 1;
+    }
+
+    Z3_context ctx = Z3_mk_context(cfg);
+    Z3_del_config(cfg);
+
+    if (!ctx) {
+        std::cerr << "(error \"failed to create Z3 context\")\n";
+        return 1;
+    }
+
+    // Avoid default handler aborting process; poll error code explicitly.
+    Z3_set_error_handler(ctx, nullptr);
+
+    Z3_string out = Z3_eval_smtlib2_string(ctx, input.c_str());
+    if (out && out[0] != '\0') {
+        std::cout << out;
+    }
+
+    Z3_error_code ec = Z3_get_error_code(ctx);
+    if (ec != Z3_OK) {
+        Z3_string msg = Z3_get_error_msg(ctx, ec);
+        if (msg && msg[0] != '\0') {
+            std::cerr << msg << "\n";
+        }
+        Z3_del_context(ctx);
+        return 1;
+    }
+
+    Z3_del_context(ctx);
+    return 0;
+}
